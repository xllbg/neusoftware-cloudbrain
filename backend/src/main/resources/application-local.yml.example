# 本地开发配置示例
# 复制此文件为 application-local.yml 并填入真实值
# 注意：application-local.yml 已在 .gitignore 中，不会被提交
# 敏感值不会写在这里，而是从根目录 .env 文件中加载

spring:
  datasource:
    password: ${DB_PASSWORD}  # 从 .env 读取

jwt:
  secret: ${JWT_SECRET}  # 从 .env 读取

deepseek:
  api-key: ${DEEPSEEK_API_KEY}  # 从 .env 读取，请在 platform.deepseek.com 获取
